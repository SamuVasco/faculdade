Algoritmo "7"
// Autor(a)    : Samuel Souza
// Data atual  : 14/05/2026
// 7) Crie um algoritmo que leia um n·mero real e mostre na tela o seu dobro e a
// sua terńa parte.
// Ex:
// Digite um n·mero: 3.5
// O dobro de 3.5 ķ 7.0
// A terńa parte de 3.5 ķ 1.16666

Var
   numero: Real

Inicio
      Escreva("Digite um n·mero: ")
      Leia(numero)
      Escreval("O dobro de",numero," ķ", numero*2)
      Escreva("A terńa parte de",numero," ķ", numero/3)

Fimalgoritmo