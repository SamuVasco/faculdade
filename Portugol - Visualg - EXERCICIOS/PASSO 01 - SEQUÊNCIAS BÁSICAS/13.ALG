Algoritmo "13"
// Autor(a)    : Samuel Souza
// Data atual  : 14/05/2026
// 13) FaÁa um algoritmo que leia o sal·rio de um funcion·rio, calcule e mostre o
// seu novo sal·rio, com 15% de aumento.


Var
   salario, aumento: real
   

Inicio
      Escreva("Sal·rio: R$")
      Leia(salario)
      aumento <- salario + (salario * 15 / 100)
      Escreva("Com 15% de aumento fica: R$", aumento)


Fimalgoritmo