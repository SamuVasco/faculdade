Algoritmo "12"
// Autor(a)    : Samuel Souza
// Data atual  : 14/05/2026
// 12) Crie um programa que leia o preńo de um produto, calcule e mostre o seu
// PREŪO PROMOCIONAL, com 5% de desconto.


Var
   preco, desconto: Real
   

Inicio
      Escreva("Preńo do produto: R$")
      Leia(preco)
      desconto <- preco - (preco * 5 / 100)
      Escreva("Com 5% de desconto fica: ", desconto)


Fimalgoritmo